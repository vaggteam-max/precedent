# Slack app credentials (create app from manifest.json at https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...   # App-level token with connections:write (Socket Mode)

# LLM — set ONE provider. Priority if several are set: Gemini > OpenAI-compatible > Anthropic.

# Option A: Gemini (free tier, no card — https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Option B: any OpenAI-compatible endpoint — Groq, OpenRouter, Ollama, OpenAI, GitHub Models
#   Groq:       https://api.groq.com/openai/v1        model e.g. llama-3.3-70b-versatile
#   OpenRouter: https://openrouter.ai/api/v1          model e.g. meta-llama/llama-3.3-70b-instruct:free
#   Ollama:     http://localhost:11434/v1             model e.g. llama3.1  (no API key needed)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# Option C: Anthropic (pay-as-you-go)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Storage
DB_PATH=./precedent.db

# Detection tuning
CONFIDENCE_THRESHOLD=0.6
